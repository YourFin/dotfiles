+;;; agent-shell-kiro.el --- Kiro agent configurations -*- lexical-binding: t; -*-
+
+;;; Commentary:
+;;
+;; This file includes Kiro-specific configurations.
+;;
+
+;;; Code:
+
+(eval-when-compile
+  (require 'cl-lib))
+(require 'shell-maker)
+(require 'acp)
+
+(declare-function agent-shell--indent-string "agent-shell")
+(declare-function agent-shell-make-agent-config "agent-shell")
+(autoload 'agent-shell-make-agent-config "agent-shell")
+(declare-function agent-shell--make-acp-client "agent-shell")
+(declare-function agent-shell-start "agent-shell")
+
+(defcustom agent-shell-kiro-command
+  '("kiro-cli" "acp")
+  "Command and parameters for the Kiro client."
+  :type '(repeat string)
+  :group 'agent-shell)
+
+(defcustom agent-shell-kiro-environment
+  nil
+  "Environment variables for the Kiro client."
+  :type '(repeat string)
+  :group 'agent-shell)
+
+(defun agent-shell-kiro-make-agent-config ()
+  "Create a Kiro agent configuration."
+  (agent-shell-make-agent-config
+   :identifier 'kiro
+   :mode-line-name "Kiro"
+   :buffer-name "Kiro"
+   :shell-prompt "Kiro> "
+   :shell-prompt-regexp "Kiro> "
+   :welcome-function #'agent-shell-kiro--welcome-message
+   :client-maker (lambda (buffer)
+                   (agent-shell-kiro-make-client :buffer buffer))
+   :install-instructions "Install kiro-cli and ensure it's in PATH."))
+
+(defun agent-shell-kiro-start-agent ()
+  "Start an interactive Kiro agent shell."
+  (interactive)
+  (agent-shell-start
+   :config (agent-shell-kiro-make-agent-config)))
+
+(cl-defun agent-shell-kiro-make-client (&key buffer)
+  "Create a Kiro client with BUFFER as context."
+  (unless buffer
+    (error "Missing required argument: :buffer"))
+  (agent-shell--make-acp-client :command (car agent-shell-kiro-command)
+                                :command-params (cdr agent-shell-kiro-command)
+                                :environment-variables agent-shell-kiro-environment
+                                :context-buffer buffer))
+
+(defun agent-shell-kiro--welcome-message (config)
+  "Return Kiro welcome message using `shell-maker' CONFIG."
+  (let ((art (agent-shell--indent-string 4 (agent-shell-kiro--ascii-art)))
+        (message (string-trim-left (shell-maker-welcome-message config) "\n")))
+    (concat "\n\n" art "\n\n" message)))
+
+(defun agent-shell-kiro--ascii-art ()
+  "Kiro ASCII art."
+  (let* ((is-dark (eq (frame-parameter nil 'background-mode) 'dark))
+         (text (string-trim "
+██╗  ██╗██╗██████╗  ██████╗
+██║ ██╔╝██║██╔══██╗██╔═══██╗
+█████╔╝ ██║██████╔╝██║   ██║
+██╔═██╗ ██║██╔══██╗██║   ██║
+██║  ██╗██║██║  ██║╚██████╔╝
+╚═╝  ╚═╝╚═╝╚═╝  ╚═╝ ╚═════╝" "\n")))
+    (propertize text 'font-lock-face (if is-dark
+                                         '(:foreground "#FF9900")
+                                       '(:foreground "#EC7211")))))
+
+(provide 'agent-shell-kiro)
+
+;;; agent-shell-kiro.el ends here
